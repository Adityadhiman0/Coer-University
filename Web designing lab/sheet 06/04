<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Image Display Example</title>
</head>
<body>
  <!-- Heading -->
  <h1>Welcome to My Image Webpage</h1>
  <p>This page shows how to insert and display images using HTML.</p>

  <!-- Displaying a Local Image -->
  <h2>Local Image Example</h2>
  <p>Below is an image stored in the project folder:</p>
  <img src="images/sample.jpg" alt="Sample Local Image" width="300" height="200">

  <!-- Displaying an Online Image -->
  <h2>Online Image Example</h2>
  <p>You can also display images directly from the web:</p>
  <img src="https://www.w3schools.com/html/img_chania.jpg" alt="Beautiful Landscape" width="400">

  <!-- Formatting with Paragraphs -->
  <h2>Image with Caption</h2>
  <p><img src="https://www.w3schools.com/html/pic_trulli.jpg" alt="Trulli Houses" width="300"><br>
     <small>This is a picture of Trulli houses in Italy.</small>
  </p>

  <!-- Footer -->
  <footer>
    <p>&copy; 2026 My Image Webpage</p>
  </footer>
</body>
</html>
