<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Responsive Webpage Example</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      margin: 0;
      background-color: #f9f9f9;
    }

    /* Header */
    header {
      background-color: #2e7d32;
      color: white;
      text-align: center;   /* Center alignment */
      padding: 20px;
    }

    /* Container for content */
    .container {
      width: 80%;           /* Responsive width */
      max-width: 1200px;    /* Prevents content from stretching too wide */
      margin: 20px auto;    /* Centers the container horizontally */
      background-color: #fff;
      padding: 20px;
      border: 2px solid #ccc;
      border-radius: 8px;
    }

    /* Responsive columns */
    .row {
      display: flex;
      flex-wrap: wrap;      /* Allows wrapping on smaller screens */
      gap: 20px;
    }

    .column {
      flex: 1;              /* Equal width columns */
      min-width: 250px;     /* Ensures readability on small screens */
      background-color: #e3f2fd;
      padding: 15px;
      text-align: center;
      border: 1px solid #1565c0;
      border-radius: 5px;
    }

    /* Footer */
    footer {
      background-color: #333;
      color: #fff;
      text-align: center;
      padding: 15px;
      margin-top: 20px;
    }
  </style>
</head>
<body>
  <!-- Header -->
  <header>
    <h1>Responsive Webpage Layout</h1>
    <p>Using CSS width and alignment</p>
  </header>

  <!-- Main Content -->
  <div class="container">
    <h2>Welcome</h2>
    <p>This container is centered and adjusts its width based on the screen size.</p>

    <div class="row">
      <div class="column">
        <h3>Column 1</h3>
        <p>This column adapts to screen width.</p>
      </div>
      <div class="column">
        <h3>Column 2</h3>
        <p>Content stays aligned and responsive.</p>
      </div>
      <div class="column">
        <h3>Column 3</h3>
        <p>On smaller screens, columns stack vertically.</p>
      </div>
    </div>
  </div>

  <!-- Footer -->
  <footer>
    <p>&copy; 2026 Responsive Webpage Demo</p>
  </footer>
</body>
</html>
