<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Lists Example Webpage</title>
</head>
<body>
  <!-- Heading -->
  <h1>Welcome to My Webpage</h1>
  <p>This page demonstrates how to use ordered and unordered lists in HTML.</p>

  <!-- Unordered List -->
  <h2>My Favorite Fruits (Unordered List)</h2>
  <ul>
    <li>Apple</li>
    <li>Banana</li>
    <li>Mango</li>
    <li>Orange</li>
  </ul>

  <!-- Ordered List -->
  <h2>Steps to Make Tea (Ordered List)</h2>
  <ol>
    <li>Boil water</li>
    <li>Add tea leaves</li>
    <li>Let it simmer</li>
    <li>Pour into a cup</li>
    <li>Add sugar and milk (optional)</li>
  </ol>

  <!-- Nested Lists -->
  <h2>Daily Routine (Mixed List)</h2>
  <ol>
    <li>Morning
      <ul>
        <li>Wake up</li>
        <li>Exercise</li>
        <li>Breakfast</li>
      </ul>
    </li>
    <li>Afternoon
      <ul>
        <li>Work/Study</li>
        <li>Lunch</li>
      </ul>
    </li>
    <li>Evening
      <ul>
        <li>Relax</li>
        <li>Dinner</li>
      </ul>
    </li>
  </ol>

  <!-- Footer -->
  <footer>
    <p>&copy; 2026 My Webpage Example</p>
  </footer>
</body>
</html>
