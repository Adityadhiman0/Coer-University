#include <iostream>
#include <stack>
#include <string>
using namespace std;

string reverseString(const string& str) {
    stack<char> s;

    // Push all characters onto the stack
    for (char c : str) {
        s.push(c);
    }

    // Pop characters to build reversed string
    string reversed = "";
    while (!s.empty()) {
        reversed += s.top();
        s.pop();
    }

    return reversed;
}

int main() {
    string input;
    cout << "Enter a string: ";
    getline(cin, input);

    string output = reverseString(input);
    cout << "Reversed string: " << output << endl;

    return 0;
}

