#include <iostream>
#include <stack>
using namespace std;

int reverseNumber(int num) {
    stack<int> s;

    // Push digits onto the stack
    while (num > 0) {
        s.push(num % 10);
        num /= 10;
    }

    // Pop digits to form reversed number
    int reversed = 0;
    int place = 1;
    while (!s.empty()) {
        reversed += s.top() * place;
        s.pop();
        place *= 10;
    }

    return reversed;
}

int main() {
    int number;
    cout << "Enter a number: ";
    cin >> number;

    cout << "Reversed number: " << reverseNumber(number) << endl;

    return 0;
}
