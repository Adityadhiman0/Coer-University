#include <iostream>
#include <stack>
#include <string>
using namespace std;

bool isPalindrome(const string& str) {
    stack<char> s;

    // Push all characters onto the stack
    for (char c : str) {
        s.push(c);
    }

    // Compare characters from start with stack top
    for (char c : str) {
        if (c != s.top()) {
            return false; // mismatch found
        }
        s.pop();
    }

    return true; // all matched
}

int main() {
    string input;
    cout << "Enter a string: ";
    cin >> input;

    if (isPalindrome(input)) {
        cout << "The string is a palindrome." << endl;
    } else {
        cout << "The string is NOT a palindrome." << endl;
    }

    return 0;
}
