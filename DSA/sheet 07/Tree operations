int main() {
    cout << "=== BST Demo ===\n";
    Node* bst = nullptr;
    bst = insert(bst, 50);
    insert(bst, 30);
    insert(bst, 70);
    insert(bst, 20);
    insert(bst, 40);
    insert(bst, 60);
    insert(bst, 80);

    cout << "Inorder: "; inorder(bst); cout << "\n";
    cout << "Preorder: "; preorder(bst); cout << "\n";
    cout << "Postorder: "; postorder(bst); cout << "\n";
    cout << "Level-order: "; levelOrder(bst); cout << "\n";

    cout << "Search 40: " << (search(bst, 40) ? "Found" : "Not Found") << "\n";
    bst = deleteNode(bst, 30);
    cout << "After deleting 30, Inorder: "; inorder(bst); cout << "\n";

    cout << "\n=== AVL Demo ===\n";
    AVLNode* avl = nullptr;
    avl = insertAVL(avl, 10);
    avl = insertAVL(avl, 20);
    avl = insertAVL(avl, 30); // triggers rotation
    cout << "AVL Root after balancing: " << avl->data << "\n";

    cout << "\n=== Threaded Binary Tree Demo (inorder traversal) ===\n";
    // For brevity, manual threaded links
    ThreadedNode* t1 = new ThreadedNode(10);
    ThreadedNode* t2 = new ThreadedNode(20);
    ThreadedNode* t3 = new ThreadedNode(30);
    t1->right = t2; t1->rightThread = true;
    t2->left = t1; t2->right = t3; t2->rightThread = true;
    t3->left = t2;
    inorderThreaded(t1); // Displays threaded links traversal

    return 0;
}
